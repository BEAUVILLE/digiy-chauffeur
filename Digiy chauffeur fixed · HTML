<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>DIGIY DRIVER CHAUFFEUR - Espace Conducteur</title>
  
  <!-- Firebase SDK v8 (Compatible) -->
  <script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-app.js"></script>
  <script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-auth.js"></script>
  <script src="https://www.gstatic.com/firebasejs/8.10.1/firebase-database.js"></script>
  
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%);
      color: #f1f5f9;
      min-height: 100vh;
      padding: 20px;
    }
    
    .container {
      max-width: 1200px;
      margin: 0 auto;
    }
    
    .header {
      background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
      padding: 20px;
      border-radius: 16px;
      margin-bottom: 20px;
      display: flex;
      justify-content: space-between;
      align-items: center;
      box-shadow: 0 8px 32px rgba(249, 115, 22, 0.4);
    }
    
    .header h1 {
      font-size: 24px;
      font-weight: 900;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    
    .driver-id-badge {
      background: rgba(15, 23, 42, 0.9);
      padding: 8px 16px;
      border-radius: 999px;
      font-size: 14px;
      font-weight: 800;
      letter-spacing: 1px;
    }
    
    .screen {
      display: none;
    }
    
    .screen.active {
      display: block;
    }
    
    .card {
      background: rgba(30, 41, 59, 0.95);
      padding: 30px;
      border-radius: 16px;
      margin-bottom: 20px;
      border: 1px solid rgba(148, 163, 184, 0.3);
    }
    
    .card h2 {
      font-size: 20px;
      margin-bottom: 20px;
      color: #fed7aa;
    }
    
    .form-group {
      margin-bottom: 20px;
    }
    
    .form-group label {
      display: block;
      margin-bottom: 8px;
      font-weight: 600;
      color: #cbd5e1;
    }
    
    .form-group input,
    .form-group select {
      width: 100%;
      padding: 12px;
      border: 1px solid rgba(148, 163, 184, 0.3);
      border-radius: 8px;
      background: rgba(15, 23, 42, 0.7);
      color: #f1f5f9;
      font-size: 16px;
    }
    
    .form-group input:focus,
    .form-group select:focus {
      outline: none;
      border-color: #f97316;
      background: rgba(15, 23, 42, 0.9);
    }
    
    .btn {
      padding: 14px 28px;
      border: none;
      border-radius: 8px;
      font-size: 16px;
      font-weight: 800;
      cursor: pointer;
      transition: all 0.3s;
      width: 100%;
    }
    
    .btn-primary {
      background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
      color: #111827;
      box-shadow: 0 4px 16px rgba(249, 115, 22, 0.5);
    }
    
    .btn-primary:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(249, 115, 22, 0.6);
    }
    
    .btn-secondary {
      background: rgba(148, 163, 184, 0.2);
      color: #f1f5f9;
      border: 1px solid rgba(148, 163, 184, 0.5);
    }
    
    .btn-success {
      background: linear-gradient(135deg, #22c55e 0%, #16a34a 100%);
      color: white;
      margin-bottom: 10px;
    }
    
    .btn-danger {
      background: linear-gradient(135deg, #ef4444 0%, #dc2626 100%);
      color: white;
    }
    
    .stats-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 15px;
      margin-bottom: 20px;
    }
    
    .stat-card {
      background: rgba(15, 23, 42, 0.7);
      padding: 20px;
      border-radius: 12px;
      border: 1px solid rgba(148, 163, 184, 0.3);
    }
    
    .stat-card .label {
      font-size: 12px;
      color: #94a3b8;
      margin-bottom: 8px;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    
    .stat-card .value {
      font-size: 28px;
      font-weight: 900;
      color: #fed7aa;
    }
    
    .status-badge {
      display: inline-block;
      padding: 6px 16px;
      border-radius: 999px;
      font-size: 12px;
      font-weight: 800;
      text-transform: uppercase;
      letter-spacing: 1px;
    }
    
    .status-available {
      background: rgba(34, 197, 94, 0.2);
      color: #bbf7d0;
      border: 1px solid #22c55e;
    }
    
    .status-busy {
      background: rgba(250, 204, 21, 0.2);
      color: #fef9c3;
      border: 1px solid #facc15;
    }
    
    .status-offline {
      background: rgba(148, 163, 184, 0.2);
      color: #cbd5e1;
      border: 1px solid #94a3b8;
    }
    
    .ride-card {
      background: rgba(15, 23, 42, 0.9);
      padding: 20px;
      border-radius: 12px;
      border: 2px solid #f97316;
      margin-bottom: 15px;
      animation: pulse 2s infinite;
    }
    
    @keyframes pulse {
      0%, 100% { border-color: #f97316; }
      50% { border-color: #ea580c; }
    }
    
    .ride-card h3 {
      color: #fed7aa;
      margin-bottom: 15px;
      font-size: 18px;
    }
    
    .ride-detail {
      margin-bottom: 10px;
      display: flex;
      justify-content: space-between;
      align-items: center;
    }
    
    .ride-detail .label {
      color: #94a3b8;
      font-size: 14px;
    }
    
    .ride-detail .value {
      color: #f1f5f9;
      font-weight: 600;
    }
    
    .price-large {
      font-size: 32px;
      font-weight: 900;
      color: #22c55e;
      text-align: center;
      margin: 15px 0;
    }
    
    .alert {
      padding: 15px;
      border-radius: 8px;
      margin-bottom: 20px;
    }
    
    .alert-success {
      background: rgba(34, 197, 94, 0.2);
      color: #bbf7d0;
      border: 1px solid #22c55e;
    }
    
    .alert-error {
      background: rgba(239, 68, 68, 0.2);
      color: #fecaca;
      border: 1px solid #ef4444;
    }
    
    .alert-info {
      background: rgba(34, 211, 238, 0.2);
      color: #a5f3fc;
      border: 1px solid #22d3ee;
    }
    
    .loading {
      text-align: center;
      padding: 40px;
      color: #94a3b8;
    }
    
    .toggle-group {
      display: flex;
      gap: 10px;
      margin-bottom: 20px;
    }
    
    .toggle-btn {
      flex: 1;
      padding: 12px;
      border: 1px solid rgba(148, 163, 184, 0.3);
      background: rgba(15, 23, 42, 0.7);
      color: #cbd5e1;
      border-radius: 8px;
      cursor: pointer;
      font-weight: 600;
      transition: all 0.3s;
    }
    
    .toggle-btn.active {
      background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
      color: #111827;
      border-color: #f97316;
    }
    
    .gps-info {
      background: rgba(34, 211, 238, 0.1);
      padding: 15px;
      border-radius: 8px;
      border: 1px solid rgba(34, 211, 238, 0.3);
      margin-top: 15px;
    }
    
    .gps-info p {
      margin: 5px 0;
      font-size: 14px;
    }
    
    .hidden {
      display: none !important;
    }
  </style>
</head>
<body>
  <div class="container">
    <!-- HEADER -->
    <div class="header">
      <h1>🚕 DIGIY DRIVER CHAUFFEUR</h1>
      <div id="headerDriverId" class="driver-id-badge hidden"></div>
    </div>
    
    <!-- SCREEN 1 : ACCUEIL / CHOIX -->
    <div id="screenHome" class="screen active">
      <div class="card">
        <h2>Bienvenue, Chauffeur DIGIY</h2>
        <p style="margin-bottom: 20px; color: #cbd5e1;">
          Choisissez une action pour commencer :
        </p>
        <button class="btn btn-primary" onclick="showScreen('screenLogin')">
          Se connecter
        </button>
        <button class="btn btn-secondary" onclick="showScreen('screenRegister')" style="margin-top: 10px;">
          Créer un compte chauffeur
        </button>
      </div>
    </div>
    
    <!-- SCREEN 2 : INSCRIPTION -->
    <div id="screenRegister" class="screen">
      <div class="card">
        <h2>Inscription Chauffeur</h2>
        <div id="registerAlert"></div>
        
        <div class="form-group">
          <label>Prénom *</label>
          <input type="text" id="regFirstName" placeholder="Ex: Abdoulaye">
        </div>
        
        <div class="form-group">
          <label>Nom *</label>
          <input type="text" id="regLastName" placeholder="Ex: Diop">
        </div>
        
        <div class="form-group">
          <label>Téléphone (format: +221XXXXXXXXX) *</label>
          <input type="tel" id="regPhone" placeholder="+221771342889">
        </div>
        
        <div class="form-group">
          <label>Carte d'Identité (CNI) *</label>
          <input type="text" id="regCni" placeholder="150012345678">
        </div>
        
        <div class="form-group">
          <label>Email *</label>
          <input type="email" id="regEmail" placeholder="exemple@email.com">
        </div>
        
        <div class="form-group">
          <label>Mot de passe (min 6 caractères) *</label>
          <input type="password" id="regPassword" placeholder="••••••">
        </div>
        
        <h3 style="margin: 25px 0 15px; color: #fed7aa;">Informations Véhicule</h3>
        
        <div class="form-group">
          <label>Marque et Modèle *</label>
          <input type="text" id="regCarModel" placeholder="Ex: Toyota Corolla 2020">
        </div>
        
        <div class="form-group">
          <label>Couleur *</label>
          <input type="text" id="regCarColor" placeholder="Ex: Blanche">
        </div>
        
        <div class="form-group">
          <label>Plaque d'immatriculation *</label>
          <input type="text" id="regCarPlate" placeholder="Ex: DK-1234-AB">
        </div>
        
        <button class="btn btn-primary" onclick="registerDriver()">
          Créer mon compte chauffeur
        </button>
        
        <button class="btn btn-secondary" onclick="showScreen('screenHome')" style="margin-top: 10px;">
          Retour
        </button>
      </div>
    </div>
    
    <!-- SCREEN 3 : CONNEXION -->
    <div id="screenLogin" class="screen">
      <div class="card">
        <h2>Connexion Chauffeur</h2>
        <div id="loginAlert"></div>
        
        <div class="form-group">
          <label>ID Chauffeur OU Email</label>
          <input type="text" id="loginIdentifier" placeholder="CHA-2889-5678 ou email@exemple.com">
          <small style="color: #94a3b8;">
            Utilisez votre ID chauffeur (CHA-XXXX-YYYY) ou votre email
          </small>
        </div>
        
        <div class="form-group">
          <label>Mot de passe</label>
          <input type="password" id="loginPassword" placeholder="••••••">
        </div>
        
        <button class="btn btn-primary" onclick="loginDriver()">
          Se connecter
        </button>
        
        <button class="btn btn-secondary" onclick="showScreen('screenHome')" style="margin-top: 10px;">
          Retour
        </button>
      </div>
    </div>
    
    <!-- SCREEN 4 : DASHBOARD CHAUFFEUR -->
    <div id="screenDashboard" class="screen">
      <!-- Stats -->
      <div class="card">
        <h2>Mon Profil</h2>
        <div id="driverInfo"></div>
        
        <div class="stats-grid" style="margin-top: 20px;">
          <div class="stat-card">
            <div class="label">Courses Totales</div>
            <div class="value" id="statTotalRides">0</div>
          </div>
          <div class="stat-card">
            <div class="label">Note Moyenne</div>
            <div class="value" id="statRating">0.0</div>
          </div>
          <div class="stat-card">
            <div class="label">Taux Acceptation</div>
            <div class="value" id="statAcceptance">0%</div>
          </div>
          <div class="stat-card">
            <div class="label">Statut</div>
            <div id="statStatus">-</div>
          </div>
        </div>
      </div>
      
      <!-- Contrôle Disponibilité -->
      <div class="card">
        <h2>Disponibilité</h2>
        <div class="toggle-group">
          <button class="toggle-btn" id="btnAvailable" onclick="setDriverStatus('available')">
            ✅ Disponible
          </button>
          <button class="toggle-btn active" id="btnOffline" onclick="setDriverStatus('offline')">
            ⏹️ Hors ligne
          </button>
        </div>
        <div id="gpsStatus" class="gps-info hidden">
          <p>📍 GPS actif</p>
          <p id="gpsCoords">Position : En attente...</p>
          <p id="gpsAccuracy">Précision : -</p>
        </div>
      </div>
      
      <!-- Demandes de Courses -->
      <div class="card">
        <h2>Demandes de Courses</h2>
        <div id="pendingRides">
          <p class="loading">Aucune demande pour le moment...</p>
        </div>
      </div>
      
      <!-- Course en Cours -->
      <div class="card hidden" id="currentRideCard">
        <h2>Course en Cours</h2>
        <div id="currentRideInfo"></div>
      </div>
      
      <!-- Déconnexion -->
      <button class="btn btn-danger" onclick="logoutDriver()">
        Déconnexion
      </button>
    </div>
  </div>
  
  <script>
    // ============================================
    // TEST FIREBASE CHARGÉ
    // ============================================
    console.log('🔥 Firebase disponible ?', typeof firebase !== 'undefined');
    
    if (typeof firebase === 'undefined') {
      alert('❌ ERREUR : Firebase ne se charge pas. Vérifiez votre connexion Internet.');
    }
    
    // ============================================
    // CONFIGURATION FIREBASE
    // ============================================
    const firebaseConfig = {
      apiKey: "AIzaSyDCx8dKYBxVsJMeyXQxvV3B8ixupOIa-nI",
      authDomain: "digiylyfe-ecosystem.firebaseapp.com",
      databaseURL: "https://digiylyfe-ecosystem-default-rtdb.europe-west1.firebasedatabase.app",
      projectId: "digiylyfe-ecosystem",
      storageBucket: "digiylyfe-ecosystem.firebasestorage.app",
      messagingSenderId: "1035612847940",
      appId: "1:1035612847940:web:cdeafd5b8b2a22fb1abde7"
    };
    
    firebase.initializeApp(firebaseConfig);
    const auth = firebase.auth();
    const db = firebase.database();
    
    console.log('✅ Firebase initialisé !');
    
    // ============================================
    // VARIABLES GLOBALES
    // ============================================
    let currentDriver = null;
    let currentDriverId = null;
    let gpsWatchId = null;
    let pendingRidesListener = null;
    
    // ============================================
    // GESTION DES ÉCRANS
    // ============================================
    function showScreen(screenId) {
      document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
      document.getElementById(screenId).classList.add('active');
    }
    
    function showAlert(containerId, message, type = 'info') {
      const container = document.getElementById(containerId);
      container.innerHTML = `<div class="alert alert-${type}">${message}</div>`;
      setTimeout(() => container.innerHTML = '', 5000);
    }
    
    // ============================================
    // GÉNÉRATION ID CHAUFFEUR
    // ============================================
    function generateDriverId(phone, cni) {
      const phoneLast4 = phone.replace(/\D/g, '').slice(-4);
      const cniLast4 = cni.replace(/\D/g, '').slice(-4);
      return `CHA-${phoneLast4}-${cniLast4}`;
    }
    
    // ============================================
    // INSCRIPTION CHAUFFEUR
    // ============================================
    async function registerDriver() {
      const firstName = document.getElementById('regFirstName').value.trim();
      const lastName = document.getElementById('regLastName').value.trim();
      const phone = document.getElementById('regPhone').value.trim();
      const cni = document.getElementById('regCni').value.trim();
      const email = document.getElementById('regEmail').value.trim();
      const password = document.getElementById('regPassword').value;
      const carModel = document.getElementById('regCarModel').value.trim();
      const carColor = document.getElementById('regCarColor').value.trim();
      const carPlate = document.getElementById('regCarPlate').value.trim();
      
      // Validation
      if (!firstName || !lastName || !phone || !cni || !email || !password || !carModel || !carColor || !carPlate) {
        showAlert('registerAlert', '⚠️ Tous les champs sont obligatoires', 'error');
        return;
      }
      
      if (password.length < 6) {
        showAlert('registerAlert', '⚠️ Le mot de passe doit contenir au moins 6 caractères', 'error');
        return;
      }
      
      try {
        showAlert('registerAlert', '⏳ Création du compte...', 'info');
        
        // 1. Créer compte Firebase Auth
        const userCredential = await auth.createUserWithEmailAndPassword(email, password);
        const uid = userCredential.user.uid;
        
        // 2. Générer ID lisible
        const driverId = generateDriverId(phone, cni);
        
        // 3. Créer ID Firebase pour le driver
        const newDriverRef = db.ref('drivers').push();
        const firebaseDriverId = newDriverRef.key;
        
        // 4. Créer profil chauffeur
        const driverProfile = {
          driverId: driverId,
          uid: uid,
          personalInfo: {
            firstName: firstName,
            lastName: lastName,
            phone: phone,
            cni: cni,
            email: email
          },
          vehicle: {
            model: carModel,
            color: carColor,
            plate: carPlate,
            seats: 4
          },
          status: 'offline',
          position: {
            lat: null,
            lng: null,
            timestamp: null
          },
          stats: {
            rating: 0,
            totalRides: 0,
            totalTrips: 0,
            acceptanceRate: 100,
            cancellationRate: 0
          },
          createdAt: Date.now(),
          updatedAt: Date.now()
        };
        
        // 5. Sauvegarder dans Firebase
        await newDriverRef.set(driverProfile);
        
        // 6. Créer mapping ID lisible → Firebase ID
        await db.ref(`driverIdMapping/${driverId}`).set({
          firebaseDriverId: firebaseDriverId,
          createdAt: Date.now()
        });
        
        // 7. Success !
        showAlert('registerAlert', `✅ Compte créé avec succès !\n\nVotre ID : ${driverId}\n\nNotez-le précieusement !`, 'success');
        
        console.log('✅ Chauffeur créé :', driverId, '→', firebaseDriverId);
        
        setTimeout(() => {
          showScreen('screenLogin');
        }, 3000);
        
      } catch (error) {
        console.error('Erreur inscription :', error);
        showAlert('registerAlert', `❌ Erreur : ${error.message}`, 'error');
      }
    }
    
    // ============================================
    // CONNEXION CHAUFFEUR
    // ============================================
    async function loginDriver() {
      const identifier = document.getElementById('loginIdentifier').value.trim();
      const password = document.getElementById('loginPassword').value;
      
      if (!identifier || !password) {
        showAlert('loginAlert', '⚠️ Tous les champs sont obligatoires', 'error');
        return;
      }
      
      try {
        showAlert('loginAlert', '⏳ Connexion en cours...', 'info');
        
        let email = identifier;
        
        // Si c'est un ID lisible (CHA-XXXX-YYYY), retrouver l'email
        if (/^CHA-\d{4}-\d{4}$/.test(identifier)) {
          const driver = await getDriverByReadableId(identifier);
          email = driver.personalInfo.email;
          currentDriverId = identifier;
        }
        
        // Se connecter avec Firebase Auth
        await auth.signInWithEmailAndPassword(email, password);
        
        // Charger le profil
        await loadDriverProfile();
        
        showScreen('screenDashboard');
        
      } catch (error) {
        console.error('Erreur connexion :', error);
        showAlert('loginAlert', `❌ Erreur : ${error.message}`, 'error');
      }
    }
    
    // ============================================
    // RETROUVER CHAUFFEUR PAR ID LISIBLE
    // ============================================
    async function getDriverByReadableId(readableId) {
      const mappingSnapshot = await db.ref(`driverIdMapping/${readableId}`).once('value');
      
      if (!mappingSnapshot.exists()) {
        throw new Error(`Chauffeur ${readableId} introuvable`);
      }
      
      const firebaseDriverId = mappingSnapshot.val().firebaseDriverId;
      
      const driverSnapshot = await db.ref(`drivers/${firebaseDriverId}`).once('value');
      
      return {
        firebaseDriverId: firebaseDriverId,
        ...driverSnapshot.val()
      };
    }
    
    // ============================================
    // CHARGER PROFIL CHAUFFEUR
    // ============================================
    async function loadDriverProfile() {
      const user = auth.currentUser;
      if (!user) return;
      
      try {
        // Retrouver le chauffeur par UID
        const driversSnapshot = await db.ref('drivers')
          .orderByChild('uid')
          .equalTo(user.uid)
          .once('value');
        
        driversSnapshot.forEach((child) => {
          currentDriver = {
            firebaseDriverId: child.key,
            ...child.val()
          };
          currentDriverId = child.val().driverId;
        });
        
        if (!currentDriver) {
          throw new Error('Profil chauffeur introuvable');
        }
        
        // Afficher les infos
        displayDriverInfo();
        
        // Écouter les demandes de courses
        listenForPendingRides();
        
      } catch (error) {
        console.error('Erreur chargement profil :', error);
        alert('Erreur : ' + error.message);
      }
    }
    
    // ============================================
    // AFFICHER INFOS CHAUFFEUR
    // ============================================
    function displayDriverInfo() {
      const { personalInfo, vehicle, stats, status } = currentDriver;
      
      // Header
      document.getElementById('headerDriverId').textContent = currentDriverId;
      document.getElementById('headerDriverId').classList.remove('hidden');
      
      // Infos profil
      document.getElementById('driverInfo').innerHTML = `
        <p style="font-size: 18px; margin-bottom: 10px;">
          <strong>${personalInfo.firstName} ${personalInfo.lastName}</strong>
        </p>
        <p style="color: #94a3b8; margin-bottom: 5px;">📞 ${personalInfo.phone}</p>
        <p style="color: #94a3b8; margin-bottom: 10px;">🚗 ${vehicle.model} - ${vehicle.color} (${vehicle.plate})</p>
      `;
      
      // Stats
      document.getElementById('statTotalRides').textContent = stats.totalRides || stats.totalTrips || 0;
      document.getElementById('statRating').textContent = (stats.rating || 0).toFixed(1);
      document.getElementById('statAcceptance').textContent = (stats.acceptanceRate || 0) + '%';
      
      // Statut
      updateStatusDisplay(status);
    }
    
    // ============================================
    // METTRE À JOUR AFFICHAGE STATUT
    // ============================================
    function updateStatusDisplay(status) {
      const statusEl = document.getElementById('statStatus');
      let badgeClass = 'status-offline';
      let statusText = 'Hors ligne';
      
      if (status === 'available') {
        badgeClass = 'status-available';
        statusText = 'Disponible';
      } else if (status === 'busy') {
        badgeClass = 'status-busy';
        statusText = 'Occupé';
      }
      
      statusEl.innerHTML = `<span class="status-badge ${badgeClass}">${statusText}</span>`;
      
      // Boutons
      document.querySelectorAll('.toggle-btn').forEach(btn => btn.classList.remove('active'));
      
      if (status === 'available') {
        document.getElementById('btnAvailable').classList.add('active');
      } else {
        document.getElementById('btnOffline').classList.add('active');
      }
    }
    
    // ============================================
    // CHANGER STATUT CHAUFFEUR
    // ============================================
    async function setDriverStatus(newStatus) {
      if (!currentDriver) return;
      
      try {
        // Mettre à jour dans Firebase
        await db.ref(`drivers/${currentDriver.firebaseDriverId}/status`).set(newStatus);
        
        // Mettre à jour localement
        currentDriver.status = newStatus;
        updateStatusDisplay(newStatus);
        
        // GPS
        if (newStatus === 'available') {
          startGPSTracking();
        } else {
          stopGPSTracking();
        }
        
      } catch (error) {
        console.error('Erreur changement statut :', error);
        alert('Erreur : ' + error.message);
      }
    }
    
    // ============================================
    // GPS TRACKING
    // ============================================
    function startGPSTracking() {
      if (!navigator.geolocation) {
        alert('GPS non disponible sur cet appareil');
        return;
      }
      
      document.getElementById('gpsStatus').classList.remove('hidden');
      
      const options = {
        enableHighAccuracy: true,
        timeout: 5000,
        maximumAge: 0
      };
      
      gpsWatchId = navigator.geolocation.watchPosition(
        (position) => {
          const pos = {
            lat: position.coords.latitude,
            lng: position.coords.longitude,
            accuracy: position.coords.accuracy,
            timestamp: Date.now()
          };
          
          // Mettre à jour dans Firebase
          db.ref(`drivers/${currentDriver.firebaseDriverId}/position`).set(pos);
          
          // Afficher
          document.getElementById('gpsCoords').textContent = 
            `Position : ${pos.lat.toFixed(6)}, ${pos.lng.toFixed(6)}`;
          document.getElementById('gpsAccuracy').textContent = 
            `Précision : ${pos.accuracy.toFixed(0)}m`;
        },
        (error) => {
          console.error('Erreur GPS :', error);
        },
        options
      );
    }
    
    function stopGPSTracking() {
      if (gpsWatchId) {
        navigator.geolocation.clearWatch(gpsWatchId);
        gpsWatchId = null;
      }
      document.getElementById('gpsStatus').classList.add('hidden');
    }
    
    // ============================================
    // ÉCOUTER DEMANDES DE COURSES
    // ============================================
    function listenForPendingRides() {
      // Écouter les nouvelles demandes
      pendingRidesListener = db.ref('requests')
        .orderByChild('status')
        .equalTo('pending')
        .on('child_added', (snapshot) => {
          const ride = snapshot.val();
          const rideId = snapshot.key;
          displayPendingRide(rideId, ride);
        });
    }
    
    // ============================================
    // AFFICHER DEMANDE DE COURSE
    // ============================================
    function displayPendingRide(rideId, ride) {
      const container = document.getElementById('pendingRides');
      
      // Si c'est la première demande, vider le message "Aucune demande"
      if (container.querySelector('.loading')) {
        container.innerHTML = '';
      }
      
      const rideCard = document.createElement('div');
      rideCard.className = 'ride-card';
      rideCard.id = `ride-${rideId}`;
      
      rideCard.innerHTML = `
        <h3>🚕 Nouvelle Demande de Course</h3>
        
        <div class="ride-detail">
          <span class="label">📍 Départ</span>
          <span class="value">${ride.pickup?.address || 'Adresse non spécifiée'}</span>
        </div>
        
        <div class="ride-detail">
          <span class="label">📍 Destination</span>
          <span class="value">${ride.dropoff?.address || 'Adresse non spécifiée'}</span>
        </div>
        
        <div class="ride-detail">
          <span class="label">📏 Distance</span>
          <span class="value">${ride.distance || '-'} km</span>
        </div>
        
        <div class="ride-detail">
          <span class="label">⏱️ Durée estimée</span>
          <span class="value">${ride.duration || '-'} min</span>
        </div>
        
        <div class="price-large">${ride.price || 0} FCFA</div>
        
        <button class="btn btn-success" onclick="acceptRide('${rideId}')">
          ✅ Accepter la course
        </button>
        
        <button class="btn btn-secondary" onclick="refuseRide('${rideId}')">
          ❌ Refuser
        </button>
      `;
      
      container.appendChild(rideCard);
      
      // Son de notification (optionnel)
      playNotificationSound();
    }
    
    // ============================================
    // ACCEPTER UNE COURSE
    // ============================================
    async function acceptRide(rideId) {
      if (!currentDriver) return;
      
      try {
        // 1. Récupérer les données de la demande
        const requestSnapshot = await db.ref(`requests/${rideId}`).once('value');
        const request = requestSnapshot.val();
        
        if (!request) {
          alert('Cette course n\'est plus disponible');
          return;
        }
        
        // 2. Créer la course dans rides/
        const rideData = {
          ...request,
          driverId: currentDriverId,
          driverFirebaseId: currentDriver.firebaseDriverId,
          status: 'accepted',
          acceptedAt: Date.now()
        };
        
        await db.ref(`rides/${rideId}`).set(rideData);
        
        // 3. Supprimer de requests/
        await db.ref(`requests/${rideId}`).remove();
        
        // 4. Changer statut chauffeur
        await setDriverStatus('busy');
        
        // 5. Supprimer la carte de demande
        document.getElementById(`ride-${rideId}`).remove();
        
        // 6. Afficher la course en cours
        displayCurrentRide(rideId, rideData);
        
        alert('✅ Course acceptée ! Navigation activée.');
        
      } catch (error) {
        console.error('Erreur acceptation course :', error);
        alert('Erreur : ' + error.message);
      }
    }
    
    // ============================================
    // REFUSER UNE COURSE
    // ============================================
    async function refuseRide(rideId) {
      // Juste supprimer la carte
      document.getElementById(`ride-${rideId}`).remove();
      
      // Remettre le message si plus de demandes
      const container = document.getElementById('pendingRides');
      if (!container.querySelector('.ride-card')) {
        container.innerHTML = '<p class="loading">Aucune demande pour le moment...</p>';
      }
    }
    
    // ============================================
    // AFFICHER COURSE EN COURS
    // ============================================
    function displayCurrentRide(rideId, ride) {
      const card = document.getElementById('currentRideCard');
      const info = document.getElementById('currentRideInfo');
      
      info.innerHTML = `
        <div class="ride-detail">
          <span class="label">📍 Départ</span>
          <span class="value">${ride.pickup?.address || '-'}</span>
        </div>
        
        <div class="ride-detail">
          <span class="label">📍 Destination</span>
          <span class="value">${ride.dropoff?.address || '-'}</span>
        </div>
        
        <div class="price-large">${ride.price || 0} FCFA</div>
        
        <button class="btn btn-success" onclick="completeRide('${rideId}')">
          ✅ Terminer la course
        </button>
      `;
      
      card.classList.remove('hidden');
    }
    
    // ============================================
    // TERMINER UNE COURSE
    // ============================================
    async function completeRide(rideId) {
      if (!currentDriver) return;
      
      try {
        // 1. Mettre à jour le statut de la course
        await db.ref(`rides/${rideId}`).update({
          status: 'completed',
          completedAt: Date.now()
        });
        
        // 2. Mettre à jour les stats du chauffeur
        const newTotalRides = (currentDriver.stats.totalRides || 0) + 1;
        await db.ref(`drivers/${currentDriver.firebaseDriverId}/stats/totalRides`).set(newTotalRides);
        
        // 3. Changer statut chauffeur
        await setDriverStatus('available');
        
        // 4. Cacher la carte course en cours
        document.getElementById('currentRideCard').classList.add('hidden');
        
        // 5. Recharger le profil
        await loadDriverProfile();
        
        alert('✅ Course terminée ! Félicitations.');
        
      } catch (error) {
        console.error('Erreur fin de course :', error);
        alert('Erreur : ' + error.message);
      }
    }
    
    // ============================================
    // DÉCONNEXION
    // ============================================
    async function logoutDriver() {
      if (confirm('Voulez-vous vraiment vous déconnecter ?')) {
        try {
          // Arrêter GPS
          stopGPSTracking();
          
          // Arrêter écoute demandes
          if (pendingRidesListener) {
            db.ref('requests').off('child_added', pendingRidesListener);
          }
          
          // Mettre statut offline
          if (currentDriver) {
            await db.ref(`drivers/${currentDriver.firebaseDriverId}/status`).set('offline');
          }
          
          // Déconnexion Firebase Auth
          await auth.signOut();
          
          // Reset
          currentDriver = null;
          currentDriverId = null;
          
          // Retour accueil
          showScreen('screenHome');
          
        } catch (error) {
          console.error('Erreur déconnexion :', error);
        }
      }
    }
    
    // ============================================
    // NOTIFICATION SONORE
    // ============================================
    function playNotificationSound() {
      try {
        const audioContext = new (window.AudioContext || window.webkitAudioContext)();
        const oscillator = audioContext.createOscillator();
        const gainNode = audioContext.createGain();
        
        oscillator.connect(gainNode);
        gainNode.connect(audioContext.destination);
        
        oscillator.frequency.value = 800;
        oscillator.type = 'sine';
        
        gainNode.gain.setValueAtTime(0.3, audioContext.currentTime);
        gainNode.gain.exponentialRampToValueAtTime(0.01, audioContext.currentTime + 0.5);
        
        oscillator.start(audioContext.currentTime);
        oscillator.stop(audioContext.currentTime + 0.5);
      } catch (e) {
        console.log('Son désactivé');
      }
    }
    
    // ============================================
    // VÉRIFIER SI DÉJÀ CONNECTÉ AU CHARGEMENT
    // ============================================
    auth.onAuthStateChanged(async (user) => {
      if (user) {
        await loadDriverProfile();
        showScreen('screenDashboard');
      }
    });
  </script>
</body>
