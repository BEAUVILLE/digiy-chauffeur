<!doctype html>
<html lang="fr">
<head>
  <meta charset="utf-8"/>
  <meta name="viewport" content="width=device-width,initial-scale=1,viewport-fit=cover"/>
  <meta name="theme-color" content="#123c2d"/>
  <meta name="robots" content="index,follow"/>
  <meta name="digiy-version" content="inscription-driver-fiche-mobile-terrain-wave-20260601"/>
  <title>Inscription chauffeur — DIGIY DRIVER</title>
  <meta name="description" content="Inscription chauffeur DIGIY DRIVER : Jakarta, bus, taxi-local, VTC, chauffeur privé. Contact direct, 0% commission, fiche chauffeur et QR."/>
  <style>
    :root{
      --bg:#123c2d;
      --bg2:#071b14;
      --card:#174b38;
      --soft:rgba(255,255,255,.075);
      --soft2:rgba(250,204,21,.10);
      --line:rgba(255,255,255,.18);
      --text:#f7fff9;
      --muted:rgba(247,255,249,.82);
      --gold:#facc15;
      --gold2:#f59e0b;
      --green:#22c55e;
      --red:#fecaca;
      --shadow:0 18px 48px rgba(0,0,0,.28);
      --radius:24px;
    }
    *{box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{
      margin:0;
      min-height:100vh;
      font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial,sans-serif;
      background:
        radial-gradient(circle at top left,rgba(34,197,94,.18),transparent 34%),
        radial-gradient(circle at bottom right,rgba(250,204,21,.12),transparent 32%),
        linear-gradient(180deg,var(--bg),var(--bg2));
      color:var(--text);
      font-size:18px;
      font-weight:850;
      padding-bottom:96px;
    }
    a{color:inherit;text-decoration:none}
    button,input,select,textarea{font:inherit}
    .wrap{max-width:1040px;margin:auto;padding:14px}
    .top{
      position:sticky;top:0;z-index:20;
      margin:-14px -14px 14px;
      padding:12px 14px;
      background:rgba(18,60,45,.94);
      backdrop-filter:blur(12px);
      border-bottom:1px solid var(--line);
      display:flex;justify-content:space-between;align-items:center;gap:10px;flex-wrap:wrap;
    }
    .brand{font-weight:1000;color:#fff8db;letter-spacing:-.02em}
    .nav{display:flex;gap:8px;flex-wrap:wrap}
    .btn{
      min-height:48px;border-radius:999px;border:1px solid var(--line);
      background:rgba(255,255,255,.08);color:var(--text);
      display:inline-flex;align-items:center;justify-content:center;
      padding:0 15px;font-weight:1000;cursor:pointer;text-align:center;
    }
    .btn.gold{background:linear-gradient(135deg,var(--gold),var(--gold2));color:#061b14;border:0}
    .btn.green{background:linear-gradient(135deg,var(--green),#16a34a);color:#04150d;border:0}
    .btn.full{width:100%}
    .hero{
      border:1px solid var(--line);
      border-radius:28px;
      background:linear-gradient(180deg,rgba(25,82,60,.96),rgba(16,61,46,.96));
      box-shadow:var(--shadow);
      padding:22px;
      margin-bottom:14px;
      display:grid;
      grid-template-columns:1.15fr .85fr;
      gap:14px;
      align-items:stretch;
    }
    h1{margin:0;font-size:clamp(38px,6vw,68px);line-height:.95;font-weight:1000;letter-spacing:-.045em;color:#fff8db}
    h2{margin:0 0 10px;font-size:26px;line-height:1.08;color:#fff8db}
    h3{margin:0 0 8px;font-size:20px;color:#fff8db}
    p{color:var(--muted);line-height:1.55;font-weight:850;margin:10px 0}
    .pills{display:flex;gap:8px;flex-wrap:wrap;margin-top:14px}
    .pill{
      border:1px solid var(--line);
      background:rgba(255,255,255,.07);
      border-radius:999px;
      padding:8px 12px;
      font-size:13px;
      font-weight:1000;
      color:#fff8db;
    }
    .hero-card{
      border:1px solid rgba(250,204,21,.34);
      border-radius:24px;
      background:rgba(250,204,21,.10);
      padding:16px;
      display:grid;
      gap:10px;
      align-content:start;
    }
    .price-big{font-size:34px;line-height:1;font-weight:1000;color:#fff8db}
    .small{font-size:14px;color:var(--muted);line-height:1.45}
    .grid{display:grid;grid-template-columns:1fr 1fr;gap:14px}
    .card{
      border:1px solid var(--line);
      border-radius:var(--radius);
      background:rgba(255,255,255,.07);
      box-shadow:0 12px 30px rgba(0,0,0,.12);
      padding:16px;
    }
    .tarifs{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px}
    .tarif{
      border:1px solid var(--line);
      border-radius:20px;
      background:rgba(255,255,255,.07);
      padding:14px;
      cursor:pointer;
      min-height:145px;
      display:grid;
      gap:7px;
      text-align:left;
      color:inherit;
    }
    .tarif:hover,.tarif.active{border-color:rgba(250,204,21,.78);background:rgba(250,204,21,.13)}
    .tarif strong{font-size:19px;color:#fff8db}
    .tarif b{font-size:24px;color:#bbf7d0}
    .form{display:grid;gap:12px}
    label{display:grid;gap:7px;color:#fff8db;font-weight:1000}
    input,select,textarea{
      width:100%;
      border:1px solid rgba(255,255,255,.22);
      border-radius:16px;
      padding:13px 14px;
      background:rgba(255,255,255,.09);
      color:var(--text);
      outline:none;
      min-height:52px;
      font-weight:850;
    }
    option{color:#061b14;background:#fff}
    textarea{min-height:110px;resize:vertical;line-height:1.45}
    input::placeholder,textarea::placeholder{color:rgba(247,255,249,.58)}
    .two{display:grid;grid-template-columns:1fr 1fr;gap:10px}
    .checkgrid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
    .check{
      display:flex;align-items:center;gap:8px;
      border:1px solid var(--line);
      background:rgba(255,255,255,.055);
      border-radius:16px;
      padding:10px;
      font-size:14px;
      color:var(--muted);
    }
    .check input{width:auto;min-height:auto}
    .actions{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:4px}
    .preview{
      white-space:pre-wrap;
      border:1px dashed rgba(250,204,21,.46);
      border-radius:20px;
      padding:14px;
      background:rgba(0,0,0,.18);
      color:#f8fff9;
      min-height:180px;
      line-height:1.48;
      font-size:15px;
      font-weight:800;
    }
    .notice{
      border:1px solid rgba(34,197,94,.35);
      border-radius:20px;
      background:rgba(34,197,94,.10);
      padding:14px;
      color:#dcfce7;
      line-height:1.5;
      font-size:15px;
    }
    .paybox{
      border:1px solid rgba(34,197,94,.45);
      border-radius:24px;
      background:linear-gradient(180deg,rgba(34,197,94,.16),rgba(255,255,255,.06));
      box-shadow:0 12px 30px rgba(0,0,0,.14);
      padding:16px;
      margin-top:14px;
      display:grid;
      gap:10px;
    }
    .payline{
      display:flex;
      justify-content:space-between;
      align-items:flex-start;
      gap:12px;
      border:1px solid rgba(255,255,255,.14);
      border-radius:18px;
      background:rgba(0,0,0,.12);
      padding:12px;
    }
    .payline span{color:var(--muted);font-size:14px;font-weight:900}
    .payline strong{color:#fff8db;text-align:right;font-size:18px;line-height:1.15}
    .payamount{font-size:28px;color:#bbf7d0;font-weight:1000;line-height:1.05}
    @media(max-width:860px){.payline{display:grid}.payline strong{text-align:left}}
    .danger{
      border:1px solid rgba(254,202,202,.35);
      border-radius:20px;
      background:rgba(127,29,29,.16);
      padding:14px;
      color:#fee2e2;
      line-height:1.5;
      font-size:15px;
    }
    .footer{margin-top:16px;border:1px solid var(--line);border-radius:20px;padding:14px;background:rgba(255,255,255,.055);color:var(--muted);font-size:15px;line-height:1.5}
    .sticky{
      position:fixed;
      left:0;right:0;bottom:0;z-index:30;
      padding:10px 14px calc(10px + env(safe-area-inset-bottom));
      background:rgba(7,27,20,.92);
      backdrop-filter:blur(12px);
      border-top:1px solid var(--line);
    }
    .sticky-inner{max-width:1040px;margin:auto;display:grid;grid-template-columns:1fr 1fr;gap:10px}
    @media(max-width:860px){
      body{font-size:17px}
      .hero,.grid,.two,.tarifs{grid-template-columns:1fr}
      .nav{width:100%}
      .btn{width:100%}
      .actions,.sticky-inner{grid-template-columns:1fr}
      .hero{padding:18px;border-radius:24px}
      .card{padding:14px}
      .checkgrid{grid-template-columns:1fr}
    }
  </style>
</head>
<body>
  <main class="wrap">

    <header class="top">
      <a class="brand" href="./">∞ DIGIY DRIVER · Inscription chauffeur</a>
      <nav class="nav">
        <a class="btn" href="https://digiylyfe.com/">🌍 Site</a>
        <a class="btn" href="https://digiy-hub.digiylyfe.com/">🧭 HUB</a>
      </nav>
    </header>

    <section class="hero">
      <div>
        <h1>Inscription chauffeur DIGIY</h1>
        <p>Tu conduis. DIGIY te donne une présence propre : fiche chauffeur, contact direct, QR, WhatsApp, visibilité locale, et zéro commission sur tes courses.</p>
        <div class="pills">
          <span class="pill">🚗 Chauffeur</span>
          <span class="pill">🛵 Jakarta</span>
          <span class="pill">🚌 Bus</span>
          <span class="pill">📲 WhatsApp direct</span>
          <span class="pill">0% commission</span>
        </div>
      </div>
      <aside class="hero-card">
        <h2>Ce que l’abonnement m’apporte</h2>
        <div class="price-big">Fiche + QR + contact direct</div>
        <p class="small">Le client voit ton nom, ton numéro, ta zone, ton type de transport et peut te contacter sans intermédiaire.</p>
        <p class="small"><b>Paiement Wave :</b> Jean Baptiste Beauville · +221 77 134 28 89</p>
        <a class="btn gold" href="#inscription">Commencer mon inscription →</a>
      </aside>
    </section>

    <section class="card" aria-label="Tarifs DRIVER">
      <h2>Choisir mon tarif DRIVER</h2>
      <p>Choisis le niveau qui correspond à ton activité. DIGIY prépare la fiche, mais rien n’est activé sans validation humaine.</p>
      <div class="tarifs" id="tarifs">
        <button class="tarif active" type="button" data-plan="1A Jakarta" data-price="5 500 FCFA / mois · 9 €">
          <strong>1A · Jakarta</strong>
          <span>Moto, Jakarta, petits trajets terrain.</span>
          <b>5 500 FCFA</b>
          <small>9 € / mois</small>
        </button>
        <button class="tarif" type="button" data-plan="1B Bus" data-price="12 000 FCFA / mois · 19 €">
          <strong>1B · Bus</strong>
          <span>Bus, navette, transport collectif local.</span>
          <b>12 000 FCFA</b>
          <small>19 € / mois</small>
        </button>
        <button class="tarif" type="button" data-plan="1C Driver" data-price="19 900 FCFA / mois · 29 €">
          <strong>1C · Driver</strong>
          <span>Taxi-local, VTC, chauffeur privé, transfert.</span>
          <b>19 900 FCFA</b>
          <small>29 € / mois</small>
        </button>
      </div>
    </section>

    <section class="paybox" aria-label="Paiement Wave DRIVER">
      <h2>💙 Paiement Wave</h2>
      <p>Avant l’activation, le chauffeur règle son abonnement sur Wave puis envoie la preuve avec sa fiche. Simple, clair, terrain.</p>
      <div class="payline">
        <span>Nom du compte Wave</span>
        <strong>JEAN BAPTISTE BEAUVILLE</strong>
      </div>
      <div class="payline">
        <span>Numéro Wave</span>
        <strong>+221 77 134 28 89</strong>
      </div>
      <div class="payline">
        <span>Montant selon tarif choisi</span>
        <strong class="payamount" id="payAmount">5 500 FCFA / mois · 9 €</strong>
      </div>
      <div class="notice">Après paiement, le chauffeur remplit la fiche, ajoute la référence Wave ou la date du paiement, puis envoie le message WhatsApp.</div>
    </section>

    <section class="grid" id="inscription">
      <form class="card form" id="driverForm">
        <h2>Ma fiche chauffeur</h2>

        <div class="two">
          <label>Nom affiché
            <input name="nom" autocomplete="name" placeholder="Ex : Lamine Chauffeur" required>
          </label>
          <label>Téléphone WhatsApp
            <input name="telephone" inputmode="tel" autocomplete="tel" placeholder="Ex : +221 77 000 00 00" required>
          </label>
        </div>

        <div class="two">
          <label>Ville / base
            <input name="ville" placeholder="Ex : Saly, Dakar, Thiès, Mbour" required>
          </label>
          <label>Zone principale
            <input name="zone" placeholder="Ex : AIBD, Petite Côte, Dakar, quartiers..." required>
          </label>
        </div>

        <div class="two">
          <label>Type de transport
            <select name="transport" required>
              <option value="">Choisir</option>
              <option>Jakarta / moto</option>
              <option>Taxi-local</option>
              <option>VTC / chauffeur privé</option>
              <option>Bus / navette</option>
              <option>Livraison</option>
              <option>Autre</option>
            </select>
          </label>
          <label>Véhicule
            <input name="vehicule" placeholder="Ex : Toyota, moto, minibus, 7 places">
          </label>
        </div>

        <div class="two">
          <label>Nombre de places
            <input name="places" inputmode="numeric" placeholder="Ex : 4, 7, 14">
          </label>
          <label>Disponibilité
            <select name="dispo">
              <option>Sur demande</option>
              <option>Tous les jours</option>
              <option>Journée</option>
              <option>Soirée</option>
              <option>24h/24 selon réservation</option>
            </select>
          </label>
        </div>

        <label>Services proposés
          <div class="checkgrid">
            <span class="check"><input type="checkbox" name="services" value="Transfert AIBD"> Transfert AIBD</span>
            <span class="check"><input type="checkbox" name="services" value="Course ville"> Course ville</span>
            <span class="check"><input type="checkbox" name="services" value="Longue distance"> Longue distance</span>
            <span class="check"><input type="checkbox" name="services" value="Tourisme / circuits"> Tourisme / circuits</span>
            <span class="check"><input type="checkbox" name="services" value="Livraison"> Livraison</span>
            <span class="check"><input type="checkbox" name="services" value="Disponible WhatsApp"> Disponible WhatsApp</span>
          </div>
        </label>

        <label>Petite présentation
          <textarea name="description" placeholder="Ex : Chauffeur sérieux basé à Saly, disponible pour transferts AIBD, courses locales et circuits Petite Côte."></textarea>
        </label>

        <label>Preuve paiement Wave / référence
          <input name="preuve" placeholder="Ex : Wave payé le 01/06 · référence ou capture envoyée">
        </label>

        <div class="actions">
          <button class="btn gold" type="submit">📲 Envoyer WhatsApp</button>
          <button class="btn" type="button" id="saveBtn">💾 Sauvegarder</button>
        </div>

        <div class="notice">DIGIY prépare ta fiche. L’activation se fait après vérification : paiement, identité, numéro, activité et cohérence de la fiche.</div>
      </form>

      <aside class="card">
        <h2>Message prêt à envoyer</h2>
        <div class="preview" id="preview"></div>
        <div class="actions">
          <button class="btn green" type="button" id="copyBtn">📋 Copier</button>
          <button class="btn" type="button" id="clearBtn">🧹 Effacer</button>
        </div>
        <div class="danger" style="margin-top:12px">
          Règle terrain : le chauffeur garde son nom, son client, son argent et sa relation. DIGIY équipe, mais ne capture pas.
        </div>
      </aside>
    </section>

    <footer class="footer">DIGIY DRIVER — Fiche chauffeur, QR, WhatsApp direct, 0% commission. Le terrain garde la main. 🦅</footer>
  </main>

  <div class="sticky">
    <div class="sticky-inner">
      <a class="btn gold" href="#inscription">🚗 Remplir ma fiche chauffeur</a>
      <button class="btn green" type="button" id="stickyWhatsapp">📲 Envoyer sur WhatsApp</button>
    </div>
  </div>

  <script>
    (function(){
      const ADMIN_WA = "221771342889";
      const WAVE_NAME = "JEAN BAPTISTE BEAUVILLE";
      const WAVE_PHONE_DISPLAY = "+221 77 134 28 89";
      const STORAGE_KEY = "digiy_driver_inscription_draft_v1";
      const form = document.getElementById("driverForm");
      const preview = document.getElementById("preview");
      const copyBtn = document.getElementById("copyBtn");
      const clearBtn = document.getElementById("clearBtn");
      const saveBtn = document.getElementById("saveBtn");
      const stickyWhatsapp = document.getElementById("stickyWhatsapp");
      const payAmount = document.getElementById("payAmount");
      const tarifButtons = Array.from(document.querySelectorAll(".tarif"));

      let selectedPlan = "1A Jakarta";
      let selectedPrice = "5 500 FCFA / mois · 9 €";

      function services(){
        return Array.from(form.querySelectorAll('input[name="services"]:checked')).map(x => x.value);
      }

      function data(){
        const fd = new FormData(form);
        return {
          nom: (fd.get("nom") || "").trim(),
          telephone: (fd.get("telephone") || "").trim(),
          ville: (fd.get("ville") || "").trim(),
          zone: (fd.get("zone") || "").trim(),
          transport: (fd.get("transport") || "").trim(),
          vehicule: (fd.get("vehicule") || "").trim(),
          places: (fd.get("places") || "").trim(),
          dispo: (fd.get("dispo") || "").trim(),
          description: (fd.get("description") || "").trim(),
          preuve: (fd.get("preuve") || "").trim(),
          services: services(),
          plan: selectedPlan,
          price: selectedPrice
        };
      }

      function message(){
        const d = data();
        return [
          "🚗 INSCRIPTION CHAUFFEUR — DIGIY DRIVER",
          "",
          "Tarif choisi : " + d.plan,
          "Prix : " + d.price,
          "",
          "💙 PAIEMENT WAVE",
          "Nom Wave : " + WAVE_NAME,
          "Numéro Wave : " + WAVE_PHONE_DISPLAY,
          "Montant à régler : " + d.price,
          "",
          "Nom affiché : " + (d.nom || "À compléter"),
          "Téléphone WhatsApp : " + (d.telephone || "À compléter"),
          "Ville / base : " + (d.ville || "À compléter"),
          "Zone principale : " + (d.zone || "À compléter"),
          "Type de transport : " + (d.transport || "À compléter"),
          "Véhicule : " + (d.vehicule || "À compléter"),
          "Nombre de places : " + (d.places || "À compléter"),
          "Disponibilité : " + (d.dispo || "À compléter"),
          "Services : " + (d.services.length ? d.services.join(", ") : "À compléter"),
          "",
          "Présentation :",
          d.description || "À compléter",
          "",
          "Preuve paiement / référence : " + (d.preuve || "À compléter"),
          "",
          "Je souhaite créer / activer ma fiche chauffeur DIGIY DRIVER."
        ].join("\n");
      }

      function refresh(){
        if(payAmount) payAmount.textContent = selectedPrice;
        preview.textContent = message();
      }

      function whatsapp(){
        const url = "https://wa.me/" + ADMIN_WA + "?text=" + encodeURIComponent(message());
        window.open(url, "_blank", "noopener,noreferrer");
      }

      function save(){
        localStorage.setItem(STORAGE_KEY, JSON.stringify(data()));
      }

      function load(){
        try{
          const raw = localStorage.getItem(STORAGE_KEY);
          if(!raw) return;
          const d = JSON.parse(raw);
          selectedPlan = d.plan || selectedPlan;
          selectedPrice = d.price || selectedPrice;
          tarifButtons.forEach(btn => {
            const active = btn.dataset.plan === selectedPlan;
            btn.classList.toggle("active", active);
          });
          ["nom","telephone","ville","zone","transport","vehicule","places","dispo","description","preuve"].forEach(name => {
            if(d[name] !== undefined && form.elements[name]) form.elements[name].value = d[name];
          });
          if(Array.isArray(d.services)){
            form.querySelectorAll('input[name="services"]').forEach(input => {
              input.checked = d.services.includes(input.value);
            });
          }
        }catch(e){}
      }

      tarifButtons.forEach(btn => {
        btn.addEventListener("click", () => {
          tarifButtons.forEach(b => b.classList.remove("active"));
          btn.classList.add("active");
          selectedPlan = btn.dataset.plan;
          selectedPrice = btn.dataset.price;
          save();
          refresh();
        });
      });

      form.addEventListener("input", refresh);
      form.addEventListener("change", refresh);

      form.addEventListener("submit", function(e){
        e.preventDefault();
        save();
        whatsapp();
      });

      stickyWhatsapp.addEventListener("click", function(){
        save();
        whatsapp();
      });

      saveBtn.addEventListener("click", function(){
        save();
        saveBtn.textContent = "✅ Sauvegardé";
        setTimeout(() => saveBtn.textContent = "💾 Sauvegarder", 1200);
      });

      copyBtn.addEventListener("click", async function(){
        try{
          await navigator.clipboard.writeText(message());
          copyBtn.textContent = "✅ Copié";
          setTimeout(() => copyBtn.textContent = "📋 Copier", 1200);
        }catch(e){
          alert("Copie impossible sur ce navigateur. Sélectionne le message et copie-le.");
        }
      });

      clearBtn.addEventListener("click", function(){
        if(confirm("Effacer la fiche en cours ?")){
          localStorage.removeItem(STORAGE_KEY);
          form.reset();
          selectedPlan = "1A Jakarta";
          selectedPrice = "5 500 FCFA / mois · 9 €";
          tarifButtons.forEach((btn, i) => btn.classList.toggle("active", i === 0));
          refresh();
        }
      });

      load();
      refresh();
    })();
  </script>
</body>
</html>
